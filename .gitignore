# ========================================
# DATASETS — NEVER COMMIT
# ========================================
data/raw/*
data/processed/*
data/export/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/export/.gitkeep
!data/examples/

# Uploaded files via API
backend/uploads/*
!backend/uploads/.gitkeep

# ========================================
# ML MODELS — Download from Google Drive
# ========================================
models/*.joblib
models/*.pkl
models/*.h5
models/*.pt
!models/.gitkeep

# ========================================
# Python
# ========================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
*.ipynb

# ========================================
# Node.js / npm  (frontend only)
# ========================================
node_modules/
npm-debug.log*
yarn-debug.log*
.pnpm-store/

# ========================================
# Environment Variables
# ========================================
.env
.env.local
.env.*.local

# ========================================
# Build Output
# ========================================
dist/
build/
.next/
.output/

# ========================================
# IDE & Editor
# ========================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ========================================
# Runtime & Temp
# ========================================
.cache/
logs/
*.log
*.tmp

# ========================================
# Database
# ========================================
*.db
*.sqlite
